{
  "name": "portal-disease",
  "version": "1.7.0-snapshot",
  "overrides": {
    "ng-mocks": {
      "@angular/common": "$@angular/common",
      "@angular/core": "$@angular/core",
      "@angular/forms": "$@angular/forms",
      "@angular/platform-browser": "$@angular/platform-browser",
      "@angular/platform-browser-dynamic": "$@angular/platform-browser-dynamic",
      "rxjs": "$rxjs",
      "zone.js": "$zone.js"
    }
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 4202",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test-local": "ng test --karma-config karma.conf.js --watch",
    "test": "ng test --karma-config karma.single-run.conf.js",
    "test:coverage": "ng test --karma-config karma.coverage.conf.js",
    "dbuild": "npm run build && npm run docker",
    "docker": "docker build -t europe-west3-docker.pkg.dev/gematik-all-infra-prod/demis-dev/portal-disease:latest .",
    "build:single-spa:portal-disease": "ng build portal-disease --configuration production",
    "serve:single-spa:portal-disease": "ng s --project portal-disease --disable-host-check --port 4202 --live-reload false",
    "clean-api": "rimraf src/api",
    "clean-cache": "rimraf .angular/cache && echo Cache cleared - next build will be slower but clean",
    "build-fresh": "npm run clean-cache && npm run build",
    "build-api": "npm run clean-api && openapi-generator-cli generate",
    "build-api-lokal": "openapi-generator-cli generate",
    "build-api-from-gitlab": "npm run clean-api && node gen-openapi-from-gitlab.js"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.4",
    "@angular/cdk": "21.2.2",
    "@angular/common": "21.2.4",
    "@angular/compiler": "21.2.4",
    "@angular/core": "21.2.4",
    "@angular/forms": "21.2.4",
    "@angular/material": "21.2.2",
    "@angular/material-date-fns-adapter": "21.2.2",
    "@angular/platform-browser": "21.2.4",
    "@angular/platform-browser-dynamic": "21.2.4",
    "@angular/router": "21.2.4",
    "@gematik/demis-portal-core-library": "3.2.1",
    "@ngx-formly/core": "7.1.0",
    "@ngx-formly/material": "7.1.0",
    "date-fns": "4.1.0",
    "lodash-es": "4.18.1",
    "luxon": "3.7.1",
    "marked": "17.0.1",
    "ngx-logger": "5.0.12",
    "rxjs": "7.8.2",
    "single-spa": "6.0.3",
    "@single-spa-community/angular": "21.0.0",
    "systemjs-webpack-interop": "2.3.7",
    "transliterator": "0.1.0",
    "tslib": "2.8.1",
    "zone.js": "0.16.1"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "21.0.3",
    "@angular-devkit/build-angular": "21.2.2",
    "@angular/build": "21.2.2",
    "@angular/cli": "21.2.2",
    "@angular/compiler-cli": "21.2.4",
    "@openapitools/openapi-generator-cli": "2.25.2",
    "@types/jasmine": "5.1.9",
    "@types/lodash-es": "4.17.12",
    "@types/luxon": "3.7.1",
    "jasmine-core": "5.9.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.1",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.1.0",
    "karma-junit-reporter": "2.0.1",
    "karma-sonarqube-unit-reporter": "0.0.23",
    "ng-mocks": "14.15.1",
    "rimraf": "6.1.2",
    "style-loader": "3.3.4",
    "typescript": "5.9.3"
  }
}
